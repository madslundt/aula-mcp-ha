# VHS tape — `aula --help` overview.
#
# Render with:
#   vhs docs/demos/help.tape
# Output:
#   docs/demos/help.gif

Output docs/demos/help.gif

Set Shell zsh
Set FontSize 16
Set Width 1100
Set Height 600
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms
Set PlaybackSpeed 1.0

# Soft prompt so the GIF reads like a clean terminal session.
Set Padding 18
Set BorderRadius 10

Type "aula --help"
Sleep 400ms
Enter
Sleep 4s
